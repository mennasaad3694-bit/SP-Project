            }
        }
    }

    
    for (size_t i = 0; i < prizes.size(); i++) window.draw(prizes[i]);
    for (size_t i = 0; i < shoots.size(); i++) window.draw(shoots[i]);

    window.draw(ship);

   
    window.draw(birdsScore);
    window.draw(lifeText);
    window.draw(levelText);

    for (int i = 0; i < eggs.size(); i++) {
        window.draw(eggs[i]);
    }




    if (isgameover) window.draw(GameText);
    if (ispaused) {
        for (int i = 0; i < num_of_text; i++) window.draw(pause_menu[i]);
    }

    window.display();
}
   




    










        





